  2026/02/19 15:17:42 PG Send: {"Type":"Parse","Name":"","Query":"-- 2) Admin read-only SELECT for core tables (projects, project_members, project_lots, lot_tasks)\nDO $$\nBEGIN\n  IF to_regclass('public.projects') IS NOT NULL THEN\n    CREATE POLICY IF NOT EXISTS \"projects_admin_select_all\" ON public.projects\n      FOR SELECT\n      TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.profiles pr\n          WHERE pr.id = auth.uid()\n            AND pr.role = 'admin'\n        )\n      );\n  END IF;\nEND;\n$$","ParameterOIDs":null}
