            AND e.owner_id = auth.uid()\n          )\n        )\n        WITH CHECK (\n          EXISTS (\n            SELECT 1\n            FROM public.excel_imports e\n            WHERE e.id = excel_import_merges.import_id\n              AND e.owner_id = auth.uid()\n          )\n        );\n    END IF;\n  END IF;\nEND;\n$$","ParameterOIDs":null}
