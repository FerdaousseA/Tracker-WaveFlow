  2026/02/19 15:41:00 PG Send: {"Type":"Parse","Name":"","Query":"/*\n  Global roles migration for WaveFlow\n  - profiles.role supports: 'chef_de_projet', 'admin', 'member'\n  - Migrate legacy values:\n      * 'admin'          -\u003e 'chef_de_projet'\n      * 'po', 'dev', ''  -\u003e 'member'\n  - Admin is global read-only: update SELECT policies (add OR role = 'admin')\n    but never grant INSERT/UPDATE/DELETE based on admin.\n*/\n\nCREATE EXTENSION IF NOT EXISTS \"pgcrypto\"","ParameterOIDs":null}
  2026/02/19 15:41:00 PG Send: {"Type":"Bind","DestinationPortal":"","PreparedStatement":"","ParameterFormatCodes":null,"Parameters":[],"ResultFormatCodes":[]}
  2026/02/19 15:41:00 PG Send: {"Type":"Describe","ObjectType":"P","Name":""}
  2026/02/19 15:41:00 PG Send: {"Type":"Execute","Portal":"","MaxRows":0}
  2026/02/19 15:41:00 PG Send: {"Type":"Parse","Name":"","Query":"-- 1) Ensure profiles.role column exists and values are normalized\nDO $$\nBEGIN\n  IF to_regclass('public.profiles') IS NOT NULL THEN\n    IF NOT EXISTS (\n      SELECT 1\n      FROM information_schema.columns\n      WHERE table_schema = 'public'\n        AND table_name = 'profiles'\n        AND column_name = 'role'\n    ) THEN\n      ALTER TABLE public.profiles\n        ADD COLUMN role text;\n    END IF;\n\n    -- Normalize legacy roles\n    UPDATE public.profiles\n    SET role = 'member'\n    WHERE role IN ('po', 'dev') OR role IS NULL OR role = '';\n\n    UPDATE public.profiles\n    SET role = 'chef_de_projet'\n    WHERE role = 'admin';\n\n    -- Constrain to the new set of roles\n    IF NOT EXISTS (\n      SELECT 1\n      FROM pg_constraint\n      WHERE conname = 'profiles_role_check'\n        AND conrelid = 'public.profiles'::regclass\n    ) THEN\n      ALTER TABLE public.profiles\n        ADD CONSTRAINT profiles_role_check\n        CHECK (role IN ('chef_de_projet', 'admin', 'member'));\n    END IF;\n  END IF;\nEND;\n$$","ParameterOIDs":null}
  2026/02/19 15:41:00 PG Send: {"Type":"Bind","DestinationPortal":"","PreparedStatement":"","ParameterFormatCodes":null,"Parameters":[],"ResultFormatCodes":[]}
  2026/02/19 15:41:00 PG Send: {"Type":"Describe","ObjectType":"P","Name":""}
  2026/02/19 15:41:00 PG Send: {"Type":"Execute","Portal":"","MaxRows":0}
  2026/02/19 15:41:00 PG Send: {"Type":"Parse","Name":"","Query":"-- 2) Admin read-only SELECT for core tables (projects, project_members, project_lots, lot_tasks)\nDO $$\nBEGIN\n  IF to_regclass('public.projects') IS NOT NULL THEN\n    CREATE POLICY IF NOT EXISTS \"projects_admin_select_all\" ON public.projects\n      FOR SELECT\n      TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.profiles pr\n          WHERE pr.id = auth.uid()\n            AND pr.role = 'admin'\n        )\n      );\n  END IF;\nEND;\n$$","ParameterOIDs":null}
  2026/02/19 15:41:00 PG Send: {"Type":"Bind","DestinationPortal":"","PreparedStatement":"","ParameterFormatCodes":null,"Parameters":[],"ResultFormatCodes":[]}
  2026/02/19 15:41:00 PG Send: {"Type":"Describe","ObjectType":"P","Name":""}
  2026/02/19 15:41:00 PG Send: {"Type":"Execute","Portal":"","MaxRows":0}
  2026/02/19 15:41:00 PG Send: {"Type":"Parse","Name":"","Query":"DO $$\nBEGIN\n  IF to_regclass('public.project_members') IS NOT NULL THEN\n    CREATE POLICY IF NOT EXISTS \"project_members_admin_select_all\" ON public.project_members\n      FOR SELECT\n      TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.profiles pr\n          WHERE pr.id = auth.uid()\n            AND pr.role = 'admin'\n        )\n      );\n  END IF;\nEND;\n$$","ParameterOIDs":null}
  2026/02/19 15:41:00 PG Send: {"Type":"Bind","DestinationPortal":"","PreparedStatement":"","ParameterFormatCodes":null,"Parameters":[],"ResultFormatCodes":[]}
