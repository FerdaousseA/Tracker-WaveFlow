  2026/02/19 15:17:42 PG Send: {"Type":"Parse","Name":"","Query":"CREATE OR REPLACE FUNCTION public.get_or_create_planning_sheet(\n  p_project_id UUID,\n  p_created_by UUID DEFAULT auth.uid()\n)\nRETURNS TABLE (\n  id UUID,\n  project_id UUID,\n  created_by UUID\n)\nLANGUAGE plpgsql\nSECURITY DEFINER\nSET search_path = public\nAS $$\nBEGIN\n  RETURN QUERY\n  INSERT INTO public.planning_sheets AS ps (project_id, created_by, updated_at)\n  VALUES (p_project_id, COALESCE(p_created_by, auth.uid()), NOW())\n  ON CONFLICT (project_id, created_by)\n  DO UPDATE SET updated_at = NOW()\n  RETURNING\n    ps.id,\n    ps.project_id,\n    ps.created_by;\nEND;\n$$","ParameterOIDs":null}
