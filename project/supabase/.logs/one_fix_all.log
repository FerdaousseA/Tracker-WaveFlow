  2026/02/19 15:41:00 PG Send: {"Type":"Parse","Name":"","Query":"DO $$\nBEGIN\n  IF to_regclass('public.lot_tasks') IS NOT NULL THEN\n    CREATE POLICY IF NOT EXISTS \"lot_tasks_admin_select_all\" ON public.lot_tasks\n      FOR SELECT\n      TO authenticated\n      USING (\n        EXISTS (\n          SELECT 1 FROM public.profiles pr\n          WHERE pr.id = auth.uid()\n            AND pr.role = 'admin'\n        )\n      );\n  END IF;\nEND;\n$$","ParameterOIDs":null}
